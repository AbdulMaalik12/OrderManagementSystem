# Server
PORT=5000
NODE_ENV=development

# MongoDB — Direct connection (use direct hosts to avoid SRV DNS issues on Windows)
# Get connection string from: https://cloud.mongodb.com
MONGO_URI=mongodb+srv://<user>:<password>@cluster.mongodb.net/orderflow?retryWrites=true&w=majority

# JWT Secrets — generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your_strong_jwt_secret_here
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=your_strong_refresh_secret_here
JWT_REFRESH_EXPIRES_IN=7d

# Frontend URL (for CORS)
CLIENT_URL=http://localhost:5173

# Google Gemini AI — Get free key at https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key_here
# Model options: gemini-2.0-flash | gemini-2.5-flash | gemma-4-31b-it | gemma-4-26b-a4b-it
GEMINI_MODEL=gemini-2.0-flash
